# CureMenu — Ortam değişkenleri (kopyala: .env)
APP_ENV=development
GOOGLE_API_KEY=your_google_gemini_api_key
# Eski tek model override'u. Bos birakilirsa rol bazli modeller kullanilir.
GOOGLE_MODEL=
GEMINI_TEXT_MODEL=gemini-3.5-flash
GEMINI_VISION_MODEL=gemini-3.5-flash
GEMINI_FAST_MODEL=gemini-3.1-flash-lite
GEMINI_EVAL_MODEL=gemini-3.5-flash
GEMINI_MODEL_FALLBACKS=gemini-3.5-flash,gemini-2.5-flash,gemini-flash-latest
TAVILY_API_KEY=optional_tavily_key

# LangSmith yalnizca development ortaminda acik opt-in ile kullanilabilir.
# Kapali beta, staging ve production ortamlarinda false kalmalidir.
LANGCHAIN_TRACING=false
LANGCHAIN_TRACING_V2=false
LANGSMITH_TRACING=false
LANGSMITH_TRACING_V2=false
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=curemenu-development

# Veritabanı (varsayılan: healmenu.db)
CUREMENU_DB_PATH=healmenu.db
CUREMENU_DB_TIMEOUT=30

# CORS (geliştirme: * | canlı: https://alanadiniz.com)
CORS_ORIGINS=*

# Lokal HTTP gelistirmede bos birakin; canlida true kullanin
JWT_SECRET_KEY=change_me_to_a_long_random_secret
CUREMENU_COOKIE_SECURE=

# Chroma ve log
CHROMA_PERSIST_DIR=./chroma_db
LOG_LEVEL=INFO
ENABLE_NEMO_GUARDRAILS=false
